# Environment Configuration
# Copy this file to .env and adjust as necessary

# Server Configuration
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Models Configuration
# Ensure paths are relative to the project root or absolute
MODEL_PATH=../models/gemma-2b-it
LORA_PATH=../models/gemma_medical_qa_final

# ML Inference Configuration
# device can be 'cpu', 'cuda', or 'auto'
DEVICE=auto
MAX_NEW_TOKENS=512
TEMPERATURE=0.7

# RAG Configuration
TOP_K_RETRIEVAL=3
MAX_QUESTION_LENGTH=500
